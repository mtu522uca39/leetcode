<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Simple MCQ Quiz</title>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <style>
        /* Minimalist Styling - No decorations */
        body { font-family: sans-serif; line-height: 1.5; color: black; background: white; }
        .quiz-container { max-width: 600px; margin: 20px; }
        .question-block { margin-bottom: 20px; border-bottom: 1px solid #ccc; padding-bottom: 10px; }
        .options label { display: block; margin: 5px 0; 
        #result-area { display: none; margin-top: 20px; border: 1px solid black; padding: 20px; }
        /* Star Styling - Plain */
        .star-rating { font-size: 40px; margin: 10px 0; }
        .star-rating span { color: #ccc; } /* Default grey */
        .star-rating span.active { color: black; } /* Active black */

        button { cursor: pointer; padding: 5px 10px; margin-top: 10px; }
    </style>
</head>
<body>
<div class="quiz-container">
    <h2>Web Quiz (10 Questions)</h2>
    <form id="quiz-form">
        <div class="question-block">
            <p>1. Which tag is used for a link?</p>
            <div class="options">
                <label><input type="radio" name="q1" value="correct"> &lt;a&gt;</label>
                <label><input type="radio" name="q1" value="wrong"> &lt;link&gt;</label>
            </div>
        </div>
        <div class="question-block">
            <p>2. CSS stands for Cascading Style ____?</p>
            <div class="options">
                <label><input type="radio" name="q2" value="correct"> Sheets</label>
                <label><input type="radio" name="q2" value="wrong"> Software</label>
            </div>
        </div>
        <div class="question-block">
            <p>3. jQuery is a JS library?</p>
            <div class="options">
                <label><input type="radio" name="q3" value="correct"> True</label>
                <label><input type="radio" name="q3" value="wrong"> False</label>
            </div>
        </div>
        <div class="question-block">
            <p>4. Which symbol is used for ID in CSS?</p>
            <div class="options">
                <label><input type="radio" name="q4" value="correct"> #</label>
                <label><input type="radio" name="q4" value="wrong"> .</label>
            </div>
        </div>
        <div class="question-block">
            <p>5. Inside which HTML element do we put JavaScript?</p>
            <div class="options">
                <label><input type="radio" name="q5" value="correct"> &lt;script&gt;</label>
                <label><input type="radio" name="q5" value="wrong"> &lt;js&gt;</label>
            </div>
        </div>
        <div class="question-block">
            <p>6. How do you create a function in JS?</p>
            <div class="options">
                <label><input type="radio" name="q6" value="correct"> function myFunction()</label>
                <label><input type="radio" name="q6" value="wrong"> function:myFunction()</label>
            </div>
        </div>
        <div class="question-block">
            <p>7. Is '64' the same as 64 in JS?</p>
            <div class="options">
                <label><input type="radio" name="q7" value="wrong"> Yes</label>
                <label><input type="radio" name="q7" value="correct"> No</label>
            </div>
        </div>
        <div class="question-block">
            <p>8. Which HTML tag is used for the largest heading?</p>
            <div class="options">
                <label><input type="radio" name="q8" value="correct"> &lt;h1&gt;</label>
                <label><input type="radio" name="q8" value="wrong"> &lt;h6&gt;</label>
            </div>
        </div>
        <div class="question-block">
            <p>9. Does jQuery require a CDN or local file?</p>
            <div class="options">
                <label><input type="radio" name="q9" value="correct"> Yes</label>
                <label><input type="radio" name="q9" value="wrong"> No</label>
            </div>
        </div>
        <div class="question-block">
            <p>10. HTML is a programming language?</p>
            <div class="options">
                <label><input type="radio" name="q10" value="wrong"> True</label>
                <label><input type="radio" name="q10" value="correct"> False (Markup)</label>
            </div>
        </div>
        <button type="button" id="submit-btn">Submit Score</button>
    </form>

    <div id="result-area">
        <p id="score-display"></p>
        <div class="star-rating">
            <span id="star1">★</span>
            <span id="star2">★</span>
            <span id="star3">★</span>
        </div>
        <button onclick="location.reload()">Reset</button>
    </div>
</div>
<script>
$(document).ready(function() {
    $('#submit-btn').click(function() {
        let score = 0;
        // Count correct answers
        $('input[type="radio"]:checked').each(function() {
            if ($(this).val() === "correct") {
                score++;
            }
        });
        // Determine star count
        let stars = 0;
        if (score > 0 && score <= 4) stars = 1;
        else if (score > 4 && score <= 8) stars = 2;
        else if (score > 8) stars = 3;
        // If score is 0, stars remains 0
        // Hide quiz, show result
        $('#quiz-form').hide();
        $('#result-area').show();
        $('#score-display').text("Score: " + score + " / 10");
        // Sequential Star Effect
        for (let i = 1; i <= stars; i++) {
            setTimeout(function() {
                $('#star' + i).addClass('active');
            }, i * 500); // 500ms delay for each star
        }
    });
});
</script>
</body>
</html>








